      "source": [
        "# Include and execute your code here\n",
        "q2c = \"\"\"\n",
        "SELECT \n",
        "    playerID,\n",
        "    CAST(SUM(H) AS FLOAT) / SUM(AB) AS batting_avg\n",
        "FROM Batting\n",
        "GROUP BY playerID\n",
        "HAVING SUM(AB) >= 100\n",
        "ORDER BY batting_avg DESC\n",
        "LIMIT 5\n",
        "\"\"\"\n",
        "\n",
        "career_batting = pd.read_sql_query(q2c, con)\n",
        "print(career_batting)"
