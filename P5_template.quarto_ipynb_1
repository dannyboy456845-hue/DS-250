      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## QUESTION|TASK 2\n",
        "\n",
        "__Clean and format the data so that it can be used in a machine learning model.__ As you format the data, you should complete each item listed below. In your final report provide example(s) of the reformatted data with a short description of the changes made.\n",
        "    a. Filter the dataset to respondents that have seen at least one film\n",
        "    a. Create a new column that converts the age ranges to a single number. Drop the age range categorical column\n",
        "    a. Create a new column that converts the education groupings to a single number. Drop the school categorical column\n",
        "    a. Create a new column that converts the income ranges to a single number. Drop the income range categorical column\n",
        "    a. Create your target (also known as \"y\" or \"label\") column based on the new income range column\n",
        "    a. One-hot encode all remaining categorical columns\n",
        "\n",
        "Steps taken: (a) filtered to 936 respondents who said \"Yes\" to having seen at least one film; (b) mapped age ranges to their midpoint values; (c) mapped education levels to ordinal integers 1–5; (d) mapped income ranges to midpoint dollar amounts; (e) created a binary target column (`income_above_50k`); (f) converted film-seen columns from title strings to 0/1, converted ranking strings to numeric, and one-hot encoded all remaining categoricals."
      ],
      "id": "fb72559e"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# (a) Keep only respondents who have seen at least one Star Wars film\n",
        "# This filters out the 250 who said \"No\" and also removes the CSV's sub-header row\n",
        "strwrs_views = df[df['seen_any'] == 'Yes'].copy()\n",
        "\n",
        "print(f\"Respondents who have seen at least one film: {len(strwrs_views)}\")\n",
        "strwrs_views[['seen_any', 'fan', 'ep_i', 'age', 'household_income', 'education']].head(3)"
      ],
      "id": "9ec9b0d2",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# (b) Convert age ranges to their numeric midpoints, then drop the original string column\n",
        "age_map = {\n",
        "    \"18-29\": 23.5,   # midpoint of 18–29\n",
        "    \"30-44\": 37.0,   # midpoint of 30–44\n",
        "    \"45-60\": 52.5,   # midpoint of 45–60\n",
        "    \"> 60\":  65.0    # approximate midpoint for open-ended 60+ range\n",
        "}\n",
        "strwrs_views['age_num'] = strwrs_views['age'].map(age_map)\n",
        "strwrs_views = strwrs_views.drop(columns=['age'])\n",
        "\n",
        "strwrs_views[['age_num']].head()"
      ],
      "id": "1b1a0aa3",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# (c) Convert education levels to ordinal integers (higher number = more education)\n",
        "edu_map = {\n",
        "    \"Less than high school degree\":     1,\n",
        "    \"High school degree\":               2,\n",
        "    \"Some college or Associate degree\": 3,\n",
        "    \"Bachelor degree\":                  4,\n",
        "    \"Graduate degree\":                  5\n",
        "}\n",
        "strwrs_views['edu_num'] = strwrs_views['education'].map(edu_map)\n",
        "strwrs_views = strwrs_views.drop(columns=['education'])\n",
        "\n",
        "strwrs_views[['edu_num']].head()"
      ],
      "id": "98421af8",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# (d) Convert income ranges to midpoint dollar values, then drop the original string column\n",
        "income_map = {\n",
        "    \"$0 - $24,999\":         12500,\n",
        "    \"$25,000 - $49,999\":    37500,\n",
        "    \"$50,000 - $99,999\":    75000,\n",
        "    \"$100,000 - $149,999\": 125000,\n",
        "    \"$150,000+\":           150000\n",
        "}\n",
        "strwrs_views['income_num'] = strwrs_views['household_income'].map(income_map)\n",
        "strwrs_views = strwrs_views.drop(columns=['household_income'])\n",
        "\n",
        "strwrs_views[['income_num']].head(10)"
      ],
      "id": "16deb0ed",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# (e) Create binary target column: 1 if income > $50k, 0 if ≤ $50k, NaN if not reported\n",
        "# We use np.where so that missing income (NaN) stays NaN instead of becoming 0\n",
        "inc = strwrs_views['income_num']\n",
        "strwrs_views['income_above_50k'] = np.where(\n",
        "    inc.isna(),             # condition: income was not reported\n",
        "    np.nan,                 # true  → keep as NaN\n",
        "    (inc > 50000).astype(float)  # false → 1.0 if > $50k, else 0.0\n",
        ")\n",
        "\n",
        "# Show a sample with both the numeric income and the new binary label\n",
        "strwrs_views[['income_num', 'income_above_50k']].dropna().head(10)"
      ],
      "id": "45fa4e85",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# (f) Encode remaining columns so everything is numeric for the ML model\n",
        "\n",
        "# Film-seen columns contain the movie title string when seen, NaN otherwise.\n",
        "# Replace with 1 (seen) or 0 (not seen).\n",
        "for col in ['ep_i', 'ep_ii', 'ep_iii', 'ep_iv', 'ep_v', 'ep_vi']:\n",
        "    strwrs_views[col] = strwrs_views[col].notna().astype(int)\n",
        "\n",
        "# Ranking columns were stored as \"1\"–\"6\" strings — convert to integers\n",
        "for col in ['rank_ep_i', 'rank_ep_ii', 'rank_ep_iii', 'rank_ep_iv', 'rank_ep_v', 'rank_ep_vi']:\n",
        "    strwrs_views[col] = pd.to_numeric(strwrs_views[col], errors='coerce')\n",
        "\n",
        "# Drop seen_any — we already used it to filter; it adds no predictive value\n",
        "strwrs_views = strwrs_views.drop(columns=['seen_any'])\n",
        "\n",
        "# One-hot encode every remaining string/categorical column (fan, character views, gender, etc.)\n",
        "# drop_first=True removes one dummy per group to avoid multicollinearity\n",
        "# Include both 'object' and 'string' dtypes (pandas 3.0+ uses StringDtype for text)\n",
        "cat_cols = strwrs_views.select_dtypes(include=['object', 'string']).columns.tolist()\n",
        "ml_df = pd.get_dummies(strwrs_views, columns=cat_cols, drop_first=True)\n",
        "\n",
        "print(f\"ML-ready dataset shape: {ml_df.shape}\")\n",
        "ml_df.head(2)"
      ],
      "id": "5644a1c7",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## QUESTION|TASK 3\n",
        "\n",
        "__Validate that the data provided on GitHub lines up with the article by recreating 2 of the visuals from the article.__\n",
        "\n",
        "The two charts below match key visuals from the FiveThirtyEight article. **Visual 1** shows film viewership as a percentage of all 1,186 respondents — *Episode V: The Empire Strikes Back* leads, which matches the article's findings. **Visual 2** shows character favorability among those who have seen at least one film — R2-D2 and Yoda are the most liked, while Jar Jar Binks is least liked, consistent with the article."
      ],
      "id": "bbf73eb0"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Exclude the CSV's sub-header row (has \"Response\" in seen_any, not a real respondent)\n",
        "valid_df = df[df['seen_any'].isin(['Yes', 'No'])].copy()\n",
        "total_n  = len(valid_df)  # 1,186 valid respondents\n",
        "\n",
        "# ── Visual 1: Film Viewership ──────────────────────────────────────────────────\n",
        "# Each ep column holds the movie title string when seen, NaN when not seen.\n",
        "film_cols   = ['ep_i', 'ep_ii', 'ep_iii', 'ep_iv', 'ep_v', 'ep_vi']\n",
        "film_labels = [\n",
        "    'Ep I: Phantom Menace',\n",
        "    'Ep II: Attack of the Clones',\n",
        "    'Ep III: Revenge of the Sith',\n",
        "    'Ep IV: A New Hope',\n",
        "    'Ep V: Empire Strikes Back',\n",
        "    'Ep VI: Return of the Jedi'\n",
        "]\n",
        "\n",
        "# Calculate % of ALL respondents who have seen each film\n",
        "pct_seen = [valid_df[col].notna().sum() / total_n * 100 for col in film_cols]\n",
        "\n",
        "film_chart = (\n",
        "    pd.DataFrame({'film': film_labels, 'pct': pct_seen})\n",
        "    .sort_values('pct', ascending=True)\n",
        "    .reset_index(drop=True)\n",
        ")\n",
        "\n",
        "# Build percentage labels for each bar\n",
        "film_chart['label'] = film_chart['pct'].apply(lambda x: f\"{x:.0f}%\")\n",
        "\n",
        "# Use scale_x_discrete(limits=...) to control bar order (avoids pd.Categorical + StringDtype crash)\n",
        "film_order = film_chart['film'].tolist()\n",
        "\n",
        "(ggplot(film_chart, aes(x='film', y='pct'))\n",
        "    + geom_bar(stat='identity', fill='#3B7DD8', width=0.7)\n",
        "    + coord_flip()\n",
        "    + geom_text(aes(label='label'), nudge_y=3, size=14)\n",
        "    + labs(\n",
        "        title=\"Which Star Wars Films Have You Seen?\",\n",
        "        subtitle=f\"% of {total_n:,} survey respondents\",\n",
        "        x='', y='Percent Who Have Seen (%)'\n",
        "    )\n",
        "    + scale_x_discrete(limits=film_order)\n",
        "    + scale_y_continuous(limits=[0, 100])\n",
        "    + theme_minimal()\n",
        "    + ggsize(900, 450)\n",
        "    + theme(plot_title=element_text(size=18),\n",
        "            plot_subtitle=element_text(size=13),\n",
        "            axis_text_y=element_text(size=13),\n",
        "            axis_text_x=element_text(size=12),\n",
        "            axis_title=element_text(size=13))\n",
        ")"
      ],
      "id": "23b610fb",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# ── Visual 2: Character Favorability ──────────────────────────────────────────\n",
        "# Base: respondents who have seen at least one film (936 people)\n",
        "seen_df = valid_df[valid_df['seen_any'] == 'Yes'].copy()\n",
        "seen_n  = len(seen_df)\n",
        "\n",
        "char_cols  = ['char_han_solo', 'char_luke', 'char_leia', 'char_anakin',\n",
        "              'char_obi_wan', 'char_palpatine', 'char_vader', 'char_lando',\n",
        "              'char_boba_fett', 'char_c3po', 'char_r2d2', 'char_jar_jar',\n",
