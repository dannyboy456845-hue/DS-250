        "# strwrs_views still has the original 'location' string column at this point\n",
        "# (ml_df was a separate copy produced by pd.get_dummies — strwrs_views was not changed)\n",
        "strwrs_views['location_num'] = strwrs_views['location'].map(location_map)\n",
        "strwrs_views = strwrs_views.drop(columns=['location'])\n",
